{
  "meta": {
    "version": "5.0-production-optimized",
    "description": "Facebook Selectors - CLEANED - Only working strategies verified Oct 1 2025",
    "last_updated": "2025-10-01",
    "note": "All fallback strategies removed. Only confirmed working selectors."
  },
  "post_containers": {
    "strategies": [
      {
        "type": "css",
        "path": "div[aria-posinset]",
        "priority": 1,
        "description": "✅ Position info - MAIN POSTS ONLY"
      },
      {
        "type": "css",
        "path": "div[role='article'][aria-posinset]",
        "priority": 2,
        "description": "✅ Article with position - MAIN POSTS ONLY"
      }
    ],
    "validation": {
      "type": "elements_found",
      "required": true,
      "min_count": 1
    }
  },
  "like_count": {
    "strategies": [
      {
        "type": "xpath",
        "path": ".//div[contains(text(), 'Tất cả cảm xúc:')]/parent::*//span[string-length(normalize-space(text())) > 0 and string-length(normalize-space(text())) < 10 and translate(normalize-space(text()), '0123456789,.KM', '') = '']",
        "priority": 1,
        "description": "✅ WORKING: Vietnamese total reactions"
      },
      {
        "type": "xpath",
        "path": ".//div[contains(text(), 'All reactions:')]/parent::*//span[string-length(normalize-space(text())) > 0 and string-length(normalize-space(text())) < 10 and translate(normalize-space(text()), '0123456789,.KM', '') = '']",
        "priority": 2,
        "description": "✅ WORKING: English total reactions"
      }
    ],
    "validation": {
      "type": "integer",
      "required": true,
      "min_value": 0,
      "max_value": 10000000
    }
  },
  "comment_count": {
    "strategies": [
      {
        "type": "xpath",
        "path": ".//span[contains(text(), 'bình luận')]",
        "priority": 1,
        "description": "✅ WORKING: Vietnamese '13 bình luận'"
      },
      {
        "type": "xpath",
        "path": ".//span[contains(text(), 'comment')]",
        "priority": 2,
        "description": "✅ WORKING: English '11 comments'"
      },
      {
        "type": "xpath",
        "path": ".//div[@role='button']//span[contains(text(), 'bình luận')]",
        "priority": 3,
        "description": "✅ Vietnamese comment button (0 comments)"
      },
      {
        "type": "xpath",
        "path": ".//div[@role='button']//span[contains(text(), 'Comment')]",
        "priority": 4,
        "description": "✅ English comment button (0 comments)"
      }
    ],
    "validation": {
      "type": "integer",
      "required": true,
      "min_value": 0,
      "max_value": 1000000
    }
  },
  "share_count": {
    "strategies": [
      {
        "type": "xpath",
        "path": ".//span[contains(text(), 'lượt chia sẻ')]",
        "priority": 1,
        "description": "✅ Vietnamese '18 lượt chia sẻ'"
      },
      {
        "type": "xpath",
        "path": ".//span[contains(text(), 'chia sẻ')]",
        "priority": 2,
        "description": "✅ Vietnamese '18 chia sẻ' (short form)"
      },
      {
        "type": "xpath",
        "path": ".//span[contains(text(), 'share')]",
        "priority": 3,
        "description": "✅ English '18 shares'"
      }
    ],
    "validation": {
      "type": "integer",
      "required": true,
      "min_value": 0,
      "max_value": 1000000
    }
  },
  "post_content": {
    "strategies": [
      {
        "type": "xpath",
        "path": "//span[string-length(normalize-space(text())) > 20 and not(contains(text(), 'Like')) and not(contains(text(), 'Comment'))]",
        "priority": 1,
        "description": "✅ WORKING: Content spans"
      }
    ],
    "validation": {
      "type": "text_not_empty",
      "required": false,
      "min_length": 1
    }
  },
  "author_name": {
    "strategies": [
      {
        "type": "css",
        "path": "strong",
        "priority": 1,
        "description": "✅ WORKING: Strong text"
      },
      {
        "type": "css",
        "path": "h3",
        "priority": 2,
        "description": "✅ WORKING: H3 heading"
      },
      {
        "type": "css",
        "path": "h1, h2, h3, h4, h5, h6",
        "priority": 3,
        "description": "✅ WORKING: Any heading"
      }
    ],
    "validation": {
      "type": "text_not_empty",
      "required": false,
      "min_length": 1,
      "max_length": 200
    }
  },
  "post_url": {
    "strategies": [
      {
        "type": "css",
        "path": "a[role='link'][href*='/posts/']",
        "priority": 1,
        "description": "✅ WORKING: Direct post links"
      }
    ],
    "validation": {
      "type": "url",
      "required": false,
      "must_contain": ["facebook.com"]
    }
  },
  "author_profile_url": {
    "strategies": [
      {
        "type": "css",
        "path": "a[href*='/user/']",
        "priority": 1,
        "description": "✅ WORKING: User profile links"
      }
    ],
    "validation": {
      "type": "url",
      "required": false,
      "must_contain": ["facebook.com"]
    }
  },
  "expand_buttons": {
    "strategies": [
      {
        "type": "css",
        "path": "div[role='button']:has-text('See more')",
        "priority": 1,
        "description": "✅ WORKING: See more buttons"
      }
    ],
    "validation": {
      "type": "elements_found",
      "required": false,
      "min_count": 0
    }
  }
}
